# Copy this file to .env and replace placeholders with your own secrets.
# Do not commit .env to version control.

# Payload CMS configuration
PAYLOAD_SECRET=your-payload-secret
DATABASE_URL=mongodb://username:password@localhost:27017/grithub

# Public frontend URL
NEXT_PUBLIC_url=http://localhost:3000

# Optional Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# SendGrid / email configuration
sendgrid_api_key=SG.xxxxxxxx
google_service_client_email=service-account@example.iam.gserviceaccount.com
server_email=you@example.com
server_email_password=your-email-password

# Sanity service configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Google Sheets service account
google_service_private_key="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
google_sheet_id=your-google-sheet-id

# PayFast sandbox credentials
sandbox_merchant_id=XXXXXXXX
sandbox_merchant_key=XXXXXXXX
passPhrase=your-passphrase

# Airtable configuration
airTable_access_token=patXXXXXXXXXXXXXX
airTable_base_id=appXXXXXXXXXXXXXX
airTable_table_id=YourTableName

# CI environment flag (optional)
CI=false